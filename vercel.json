{"$schema": "https://openapi.vercel.sh/vercel.json", "framework": "nextjs", "functions": {"app/api/**/*.ts": {"runtime": "@vercel/node@3", "maxDuration": 60}}, "headers": [{"source": "/api/(.*)", "headers": [{"key": "Cache-Control", "value": "no-store, must-revalidate"}]}, {"source": "/templates/(.*)", "headers": [{"key": "Cache-Control", "value": "public, max-age=31536000, immutable"}]}, {"source": "/(.*)", "headers": [{"key": "X-Content-Type-Options", "value": "nosniff"}, {"key": "X-Frame-Options", "value": "SAMEORIGIN"}]}]}